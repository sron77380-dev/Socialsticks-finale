function ROICalculator({ team, totalLeads }) {
  const avgLeadValue = 1500;
  const monthlyCost = team.length * 65;
  const annualCost = monthlyCost * 12;
  const estimatedRevenue = totalLeads * avgLeadValue;
  const roi = (estimatedRevenue / annualCost).toFixed(1);

  return (
    <div className="card-white" style={{ background: "linear-gradient(135deg, #fff, #faf8f5)" }}>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: "10px" }}>
        <div>
          <div style={{ fontSize: "11px", color: "var(--muted)", letterSpacing: "1px", marginBottom: "4px" }}>VOTRE ROI SOCIALSTICKS</div>
          <div style={{ fontFamily: "var(--serif)", fontSize: "28px", fontWeight: "700", color: "var(--gold)" }}>×{roi}</div>
        </div>
        <div style={{ fontSize: "40px", opacity: 0.2 }}>📊</div>
      </div>
      <div style={{ fontSize: "12px", color: "var(--muted)", lineHeight: "1.6" }}>
        <strong>{totalLeads} leads</strong> générés · Valeur estimée {estimatedRevenue.toLocaleString()}€ <br />
        vs {annualCost.toLocaleString()}€ d'abonnement
      </div>
      <div style={{ marginTop: "10px", height: "4px", background: "rgba(15,15,15,0.08)", borderRadius: "2px" }}>
        <div style={{ height: "4px", width: `${Math.min(100, roi * 20)}%`, background: "var(--gold)", borderRadius: "2px" }} />
      </div>
    </div>
  );
}

