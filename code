function TeamTab({ team, activeCount, companyColor, onToggle, onAdd, onSelect, onDelete }) {
  const [showForm, setShowForm] = useState(false);
  const [newMember, setNewMember] = useState({ name: "", title: "", agence: "", email: "", phone: "", photo: "" });
  const [searchTerm, setSearchTerm] = useState("");
  const [filterActive, setFilterActive] = useState("all");

  const totalLeads = team.reduce((a, m) => a + m.leads, 0);
  const totalMandats = team.reduce((a, m) => a + m.mandats, 0);

  const handleSubmit = (e) => {
    e.preventDefault();
    if (newMember.name) {
      onAdd(newMember);
      setNewMember({ name: "", title: "", agence: "", email: "", phone: "", photo: "" });
      setShowForm(false);
    }
  };

  const filteredTeam = team.filter(m => {
    const matchSearch = m.name.toLowerCase().includes(searchTerm.toLowerCase()) ||
                       m.title.toLowerCase().includes(searchTerm.toLowerCase()) ||
                       (m.agence || "").toLowerCase().includes(searchTerm.toLowerCase());
    const matchFilter = filterActive === "all" ? true : filterActive === "active" ? m.active : !m.active;
    return matchSearch && matchFilter;
  });

  return (
    <div>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: "16px" }}>
        <div>
          <h2 style={{ fontFamily: "var(--serif)", fontSize: "24px", fontWeight: "700" }}>Mes agents</h2>
          <p style={{ fontSize: "12px", color: "var(--muted)", marginTop: "2px" }}>{activeCount} actifs · {team.length} total</p>
        </div>
        <button className="btn-gold" style={{ padding: "12px 16px", fontSize: "13px", minHeight: "44px" }} onClick={() => setShowForm(!showForm)}>+ Ajouter</button>
      </div>

      <ROICalculator team={team} totalLeads={totalLeads} />

      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "10px", marginBottom: "16px", marginTop: "16px" }}>
        {[
          { label: "Leads générés", value: totalLeads, delta: "+40%", icon: "🎯" },
          { label: "Mandats obtenus", value: totalMandats, delta: "+23%", icon: "📋" },
        ].map((s, i) => (
          <div key={i} className="card-white">
            <div style={{ fontSize: "18px", marginBottom: "4px" }}>{s.icon}</div>
            <div style={{ fontSize: "11px", color: "var(--muted)", marginBottom: "4px" }}>{s.label}</div>
            <div style={{ fontFamily: "var(--serif)", fontSize: "28px", fontWeight: "700" }}>{s.value}</div>
            <div style={{ fontSize: "11px", color: "var(--gold)", marginTop: "3px" }}>{s.delta} ce mois</div>
          </div>
        ))}
      </div>

      <div style={{ marginBottom: "16px" }}>
        <input className="input" placeholder="Rechercher un agent ou une agence..." value={searchTerm} onChange={e => setSearchTerm(e.target.value)} style={{ marginBottom: "10px" }} />
        <div style={{ display: "flex", gap: "8px" }}>
          {["all", "active", "inactive"].map(f => (
            <button key={f} onClick={() => setFilterActive(f)} style={{
              padding: "6px 12px",
              background: filterActive === f ? "var(--gold)" : "transparent",
              color: filterActive === f ? "var(--dark)" : "var(--muted)",
              border: `1px solid ${filterActive === f ? "var(--gold)" : "var(--border)"}`,
              borderRadius: "20px", fontSize: "11px", fontWeight: "600", cursor: "pointer", textTransform: "uppercase"
            }}>
              {f === "all" ? "Tous" : f === "active" ? "Actifs" : "Inactifs"}
            </button>
          ))}
        </div>
      </div>

      {showForm && (
        <form onSubmit={handleSubmit} className="card-white" style={{ marginBottom: "16px", animation: "slideUp 0.3s ease" }}>
          <div style={{ fontFamily: "var(--serif)", fontSize: "20px", fontWeight: "700", marginBottom: "16px" }}>Nouvel agent</div>
          {[
            ["name",   "Nom complet",  "Sophie Martin"],
            ["title",  "Titre",        "Conseillère Immobilier"],
            ["agence", "Agence",       "Bordeaux Centre"],
            ["email",  "Email",        "sophie@reseau.fr"],
            ["phone",  "Téléphone",    "+33 6 00 00 00 00"],
            ["photo",  "Photo (URL)",  "https://..."],
          ].map(([key, label, placeholder]) => (
            <div key={key} style={{ marginBottom: "14px" }}>
              <label style={{ fontSize: "11px", fontWeight: "600", letterSpacing: "1px", display: "block", marginBottom: "6px", color: "var(--muted)" }}>{label.toUpperCase()}</label>
              <input className="input" type={key === "email" ? "email" : "text"} placeholder={placeholder} value={newMember[key]} onChange={e => setNewMember(prev => ({ ...prev, [key]: e.target.value }))} required={key === "name"} />
            </div>
          ))}
          <div style={{ display: "flex", gap: "10px", marginTop: "4px" }}>
            <button type="submit" className="btn-dark" style={{ flex: 1, fontSize: "14px", padding: "14px 10px" }}>Créer & commander la carte</button>
            <button type="button" className="btn-outline" style={{ padding: "14px 16px", fontSize: "14px" }} onClick={() => setShowForm(false)}>Annuler</button>
          </div>
        </form>
      )}

      <div style={{ display: "flex", flexDirection: "column", gap: "10px" }}>
        {filteredTeam.length === 0 ? (
          <div className="card-white" style={{ textAlign: "center", padding: "40px 20px" }}>
            <div style={{ fontSize: "40px", marginBottom: "12px" }}>🔍</div>
            <div style={{ fontSize: "15px", fontWeight: "500", marginBottom: "6px" }}>Aucun agent trouvé</div>
            <div style={{ fontSize: "13px", color: "var(--muted)" }}>Modifiez votre recherche</div>
          </div>
        ) : (
          filteredTeam.map(member => (
            <MemberCard key={member.id} member={member} companyColor={companyColor} onToggle={onToggle} onSelect={onSelect} onDelete={onDelete} />
          ))
        )}
      </div>
    </div>
  );
}

