          <div style={{ width: "28px", height: "28px", borderRadius: "6px", background: DEMO_COMPANY.color, display: "flex", alignItems: "center", justifyContent: "center", fontSize: "9px", fontWeight: "800", color: "#0A0A0A" }}>{DEMO_COMPANY.logo}</div>
          <div>
            <div style={{ fontSize: "13px", fontWeight: "600", lineHeight: 1 }}>{DEMO_COMPANY.name}</div>
            <div style={{ fontSize: "10px", color: "var(--gold)" }}>{DEMO_COMPANY.plan} · {DEMO_COMPANY.agences} agences</div>
          </div>
        </div>
        <button onClick={() => setView("landing")} style={{ background: "none", border: "none", fontSize: "13px", color: "var(--muted)", cursor: "pointer", padding: "8px" }}>Quitter</button>
      </div>

      <div style={{ padding: "20px" }}>
        {tab === "team"     && <TeamTab team={team} activeCount={activeCount} companyColor={DEMO_COMPANY.color} onToggle={toggleMember} onAdd={addMember} onSelect={m => { setSelectedMember(m); setView("publicProfile"); }} onDelete={deleteMember} />}
        {tab === "agences"  && <AgencesTab />}
        {tab === "nfc"      && <NFCTab />}
        {tab === "settings" && <SettingsTab company={DEMO_COMPANY} setView={setView} />}
      </div>

      <BottomNav tab={tab} setTab={setTab} />
    </div>
  );
}